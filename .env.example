# Server
PORT=3000

# RTSP camera source
RTSP_URL=rtsp://username:password@192.168.1.100:554/Preview_01_sub
RTSP_TRANSPORT=tcp

# Inference provider: "groq" (cloud) or "ollama" (local)
INFERENCE_PROVIDER=groq

# Groq (vision inference via qwen/qwen3.6-27b or another vision-capable model)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=qwen/qwen3.6-27b
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_MS=60000

# Ollama (must be running locally, or reachable at this host)
OLLAMA_HOST=http://localhost:11434
# Must be a vision-capable model, e.g. qwen3.5:2b, llava, moondream, etc.
OLLAMA_MODEL=qwen3.5:2b
OLLAMA_TIMEOUT_MS=60000

# How often (ms) to capture a frame and re-check all conditions.
# Keep this comfortably above (avg AI evaluation time * number of checklist items).
EVAL_INTERVAL_MS=8000
FRAME_CAPTURE_TIMEOUT_MS=10000

# Path to the ffmpeg binary (must be installed and on PATH, or give an absolute path)
FFMPEG_PATH=ffmpeg

# GPU stats source: "nvidia-smi" (default, for discrete NVIDIA GPUs) or
# "tegrastats" (for Jetson embedded platforms). tegrastats shows shared
# RAM/VRAM, per-core CPU load, engine frequencies, and board power.
# GPU_STATS_SOURCE=nvidia-smi
